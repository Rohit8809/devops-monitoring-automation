body {
    margin: 0;
    background: #f8fafc;
    font-family: Arial, sans-serif;
}

.sidebar {
    width: 240px;
    min-height: 100vh;
    background: #0f172a;
    position: fixed;
    left: 0;
    top: 0;
}

.sidebar .nav-link {
    color: #cbd5e1;
    padding: 12px 14px;
    margin-bottom: 6px;
    border-radius: 8px;
}

.sidebar .nav-link:hover,
.sidebar .nav-link.active {
    color: #ffffff;
    background: #8ac805;
}

.sidebar .nav-link i {
    margin-right: 10px;
}

.main-content {
    margin-left: 240px;
    min-height: 100vh;
}

.topbar {
    height: 72px;
    background: #ffffff;
    border-bottom: 1px solid #e2e8f0;
}

.summary-card {
    border: 0;
    border-radius: 12px;
}

.summary-icon {
    font-size: 30px;
    color: #2563eb;
}

.card {
    border-radius: 12px;
    border: 1px solid #e2e8f0;
}

.table th {
    color: #64748b;
    font-weight: 600;
    background: #f8fafc;
}
