@app.route('/api/metrics/cpu-history', methods=['GET'])
def cpu_history():
    """Return CPU usage history from Prometheus for dashboard graphs."""

    try:
        end_time = datetime.now().timestamp()
        start_time = end_time - 3600

        query = (
            '100 - (avg by(instance) '
            '(rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100)'
        )

        response = requests.get(
            f"{PROMETHEUS_URL}/api/v1/query_range",
            params={
                "query": query,
                "start": start_time,
                "end": end_time,
                "step": 60
            },
            timeout=15
        )

        response.raise_for_status()
        prometheus_data = response.json()

        if prometheus_data.get("status") != "success":
            return jsonify({
                "success": False,
                "message": "Prometheus returned an unsuccessful response"
            }), 502

        graph_series = []

        for item in prometheus_data.get("data", {}).get("result", []):
            instance = item.get("metric", {}).get(
                "instance",
                "Unknown Server"
            )

            values = []

            for timestamp, value in item.get("values", []):
                try:
                    cpu_value = round(float(value), 2)
                except (TypeError, ValueError):
                    continue

                values.append({
                    "timestamp": timestamp,
                    "value": cpu_value
                })

            graph_series.append({
                "instance": instance,
                "values": values
            })

        return jsonify({
            "success": True,
            "query": query,
            "range_minutes": 60,
            "series": graph_series
        }), 200

    except requests.RequestException as error:
        print("Prometheus CPU query failed:", error)

        return jsonify({
            "success": False,
            "message": "Unable to retrieve CPU metrics from Prometheus",
            "error": str(error)
        }), 502

    except Exception as error:
        print("CPU metrics API error:", error)

        return jsonify({
            "success": False,
            "message": "Unexpected CPU metrics error",
            "error": str(error)
        }), 500


@app.route('/api/servers', methods=['GET'])
def get_servers():
    """Return live server health information from Prometheus."""

    server_definitions = {
        "http://web-server:80": {
            "name": "Web Server",
            "role": "Apache HTTP frontend",
            "icon": "globe",
            "container": "web-server-container"
        },
        "http://app-server:5000/health": {
            "name": "Application Server",
            "role": "Flask application backend",
            "icon": "code-slash",
            "container": "app-server-container"
        },
        "db-server:9100": {
            "name": "Database Server",
            "role": "Database infrastructure",
            "icon": "database",
            "container": "db-server"
        },
        "monitoring-server:9100": {
            "name": "Monitoring Server",
            "role": "Monitoring infrastructure",
            "icon": "activity",
            "container": "monitoring-server"
        }
    }

    try:
        response = requests.get(
            f"{PROMETHEUS_URL}/api/v1/targets",
            timeout=10
        )
        response.raise_for_status()

        prometheus_data = response.json()

        if prometheus_data.get("status") != "success":
            return jsonify({
                "success": False,
                "message": "Prometheus returned an unsuccessful response"
            }), 502

        target_lookup = {}

        for target in prometheus_data.get("data", {}).get(
            "activeTargets",
            []
        ):
            instance = target.get("labels", {}).get("instance")

            if instance:
                target_lookup[instance] = target

        servers = []

        for instance, definition in server_definitions.items():
            target = target_lookup.get(instance)

            if target:
                health = target.get("health", "unknown")
                last_error = target.get("lastError") or None

                servers.append({
                    **definition,
                    "instance": instance,
                    "job": target.get("labels", {}).get(
                        "job",
                        "unknown"
                    ),
                    "status": (
                        "online" if health == "up" else "offline"
                    ),
                    "prometheus_health": health,
                    "last_check": target.get("lastScrape"),
                    "response_time_ms": round(
                        float(target.get("lastScrapeDuration", 0)) * 1000,
                        2
                    ),
                    "error": last_error
                })

            else:
                servers.append({
                    **definition,
                    "instance": instance,
                    "job": "unknown",
                    "status": "unknown",
                    "prometheus_health": "unknown",
                    "last_check": None,
                    "response_time_ms": None,
                    "error": "Target not found in Prometheus"
                })

        online_count = sum(
            1 for server in servers
            if server["status"] == "online"
        )

        return jsonify({
            "success": True,
            "summary": {
                "total": len(servers),
                "online": online_count,
                "offline": len(servers) - online_count
            },
            "servers": servers
        }), 200

    except requests.RequestException as error:
        print("Prometheus targets request failed:", error)

        return jsonify({
            "success": False,
            "message": "Unable to retrieve server status from Prometheus",
            "error": str(error)
        }), 502

    except Exception as error:
        print("Server status API error:", error)

        return jsonify({
            "success": False,
            "message": "Unexpected server status error",
            "error": str(error)
        }), 500

