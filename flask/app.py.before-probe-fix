@app.route('/api/tickets', methods=['GET'])
def get_live_tickets():
    """Return recent tickets directly from the existing osTicket database."""
    connection = None
    cursor = None

    try:
        limit = request.args.get("limit", default=10, type=int)
        limit = max(1, min(limit, 100))

        connection = get_osticket_connection()
        cursor = connection.cursor(dictionary=True)

        query = """
            SELECT
                t.ticket_id,
                t.number,
                COALESCE(c.subject, 'No subject') AS subject,
                COALESCE(p.priority_desc, 'Normal') AS priority,
                COALESCE(s.name, 'Unknown') AS status,
                COALESCE(s.state, 'unknown') AS status_state,
                COALESCE(d.name, 'Unknown') AS department,
                COALESCE(ue.address, 'Unknown') AS requester_email,
                t.source,
                t.isoverdue,
                t.created,
                t.lastupdate,
                t.closed
            FROM ost_ticket AS t

            LEFT JOIN ost_ticket__cdata AS c
                ON c.ticket_id = t.ticket_id

            LEFT JOIN ost_ticket_priority AS p
                ON p.priority_id = CAST(c.priority AS UNSIGNED)

            LEFT JOIN ost_ticket_status AS s
                ON s.id = t.status_id

            LEFT JOIN ost_department AS d
                ON d.id = t.dept_id

            LEFT JOIN ost_user_email AS ue
                ON ue.id = t.user_email_id

            ORDER BY t.ticket_id DESC
            LIMIT %s
        """

        cursor.execute(query, (limit,))
        rows = cursor.fetchall()

        tickets = []

        for row in rows:
            tickets.append({
                "ticket_id": row["ticket_id"],
                "number": row["number"],
                "subject": row["subject"],
                "priority": row["priority"],
                "status": row["status"],
                "status_state": row["status_state"],
                "department": row["department"],
                "requester_email": row["requester_email"],
                "source": row["source"],
                "is_overdue": bool(row["isoverdue"]),
                "created": (
                    row["created"].isoformat()
                    if row["created"]
                    else None
                ),
                "last_update": (
                    row["lastupdate"].isoformat()
                    if row["lastupdate"]
                    else None
                ),
                "closed": (
                    row["closed"].isoformat()
                    if row["closed"]
                    else None
                )
            })

        return jsonify({
            "success": True,
            "total_returned": len(tickets),
            "tickets": tickets
        }), 200

    except mysql.connector.Error as error:
        print("osTicket database error:", error)

        return jsonify({
            "success": False,
            "message": "Unable to retrieve tickets from osTicket",
            "error": str(error)
        }), 500

    finally:
        if cursor is not None:
            cursor.close()

        if connection is not None and connection.is_connected():
            connection.close()


@app.route('/api/tickets/summary', methods=['GET'])
def get_ticket_summary():
    """Return ticket counts grouped by osTicket status."""
    connection = None
    cursor = None

    try:
        connection = get_osticket_connection()
        cursor = connection.cursor(dictionary=True)

        cursor.execute("""
            SELECT
                COUNT(*) AS total,
                SUM(CASE WHEN s.state = 'open' THEN 1 ELSE 0 END)
                    AS open_count,
                SUM(CASE WHEN s.state = 'closed' THEN 1 ELSE 0 END)
                    AS closed_count,
                SUM(CASE WHEN t.isoverdue = 1 THEN 1 ELSE 0 END)
                    AS overdue_count
            FROM ost_ticket AS t
            LEFT JOIN ost_ticket_status AS s
                ON s.id = t.status_id
        """)

        summary = cursor.fetchone()

        return jsonify({
            "success": True,
            "total": int(summary["total"] or 0),
            "open": int(summary["open_count"] or 0),
            "closed": int(summary["closed_count"] or 0),
            "overdue": int(summary["overdue_count"] or 0)
        }), 200

    except mysql.connector.Error as error:
        print("osTicket summary error:", error)

        return jsonify({
            "success": False,
            "message": "Unable to retrieve osTicket summary",
            "error": str(error)
        }), 500

    finally:
        if cursor is not None:
            cursor.close()

        if connection is not None and connection.is_connected():
            connection.close()




ALERTMANAGER_URL = os.getenv(
    "ALERTMANAGER_URL",
    "http://alertmanager:9093"
)


@app.route('/api/alerts', methods=['GET'])
def get_active_alerts():
    """Return active alerts directly from Alertmanager."""
    try:
        response = requests.get(
            f"{ALERTMANAGER_URL}/api/v2/alerts",
            timeout=10
        )
        response.raise_for_status()

        raw_alerts = response.json()
        alerts = []

        for alert in raw_alerts:
            labels = alert.get("labels", {})
            annotations = alert.get("annotations", {})
            status = alert.get("status", {})

            alerts.append({
                "fingerprint": alert.get("fingerprint"),
                "alertname": labels.get("alertname", "Unknown Alert"),
                "instance": labels.get("instance", "Unknown Instance"),
                "severity": labels.get("severity", "unknown"),
                "priority": labels.get("priority", "P3"),
                "state": status.get("state", "unknown"),
                "silenced_by": status.get("silencedBy", []),
                "inhibited_by": status.get("inhibitedBy", []),
                "summary": annotations.get("summary", "No summary"),
                "description": annotations.get(
                    "description",
                    "No description"
                ),
                "starts_at": alert.get("startsAt"),
                "ends_at": alert.get("endsAt"),
                "generator_url": alert.get("generatorURL")
            })

        alerts.sort(
            key=lambda item: (
                item["severity"] != "critical",
                item["starts_at"] or ""
            )
        )

        return jsonify({
            "success": True,
            "total": len(alerts),
            "alerts": alerts
        }), 200

    except requests.RequestException as error:
        print("Alertmanager query failed:", error)

        return jsonify({
            "success": False,
            "message": "Unable to retrieve alerts from Alertmanager",
            "error": str(error)
        }), 502


@app.route('/api/alerts/summary', methods=['GET'])
def get_alert_summary():
    """Return active Alertmanager alert counts."""
    try:
        response = requests.get(
            f"{ALERTMANAGER_URL}/api/v2/alerts",
            timeout=10
        )
        response.raise_for_status()

        raw_alerts = response.json()

        critical = 0
        warning = 0

        for alert in raw_alerts:
            severity = (
                alert.get("labels", {})
                .get("severity", "")
                .lower()
            )

            if severity == "critical":
                critical += 1
            elif severity in {"warning", "warn"}:
                warning += 1

        return jsonify({
            "success": True,
            "active": len(raw_alerts),
            "critical": critical,
            "warning": warning
        }), 200

    except requests.RequestException as error:
        print("Alertmanager summary failed:", error)

        return jsonify({
            "success": False,
            "message": "Unable to retrieve Alertmanager summary",
            "error": str(error)
        }), 502



