docker_client = docker.from_env()

# Protect the dashboard backend and database from accidental shutdown.
CORE_CONTAINERS = {
    "flask-container",
    "osticket-db-container"
}

CRITICAL_CONTAINERS = {
    "prometheus-container",
    "alertmanager-container",
    "osticket-container",
    "grafana-container"
}


@app.route('/api/containers', methods=['GET'])
def get_containers():
    """Return all Docker containers directly from Docker Engine."""
    try:
        containers = docker_client.containers.list(all=True)
        container_data = []

        for container in containers:
            image_tags = container.image.tags

            container_data.append({
                "id": container.short_id,
                "name": container.name,
                "image": image_tags[0] if image_tags else container.image.short_id,
                "status": container.status,
                "created": container.attrs.get("Created"),
                "ports": container.attrs.get("NetworkSettings", {}).get("Ports", {}),
                "action_allowed": container.name not in CORE_CONTAINERS,
                "protection_level": (
                    "core"
                    if container.name in CORE_CONTAINERS
                    else "critical"
                    if container.name in CRITICAL_CONTAINERS
                    else "normal"
                )
            })

        container_data.sort(key=lambda item: item["name"].lower())

        return jsonify({
            "success": True,
            "total": len(container_data),
            "running": sum(
                1 for item in container_data if item["status"] == "running"
            ),
            "containers": container_data
        }), 200

    except DockerException as error:
        print("Docker API error:", error)

        return jsonify({
            "success": False,
            "message": "Unable to connect to Docker Engine",
            "error": str(error)
        }), 500


@app.route(
    '/api/containers/<string:container_name>/<string:action>',
    methods=['POST']
)
def control_container(container_name, action):
    """Start, stop or restart an approved Docker container."""

    allowed_actions = {"start", "stop", "restart"}

    if action not in allowed_actions:
        return jsonify({
            "success": False,
            "message": f"Unsupported action: {action}"
        }), 400

    if container_name in CORE_CONTAINERS:
        return jsonify({
            "success": False,
            "message": (
                f"Action blocked for {container_name}. "
                "This container is protected."
            )
        }), 403

    try:
        container = docker_client.containers.get(container_name)

        if action == "start":
            if container.status == "running":
                return jsonify({
                    "success": True,
                    "message": f"{container_name} is already running"
                }), 200

            container.start()

        elif action == "stop":
            if container.status != "running":
                return jsonify({
                    "success": True,
                    "message": f"{container_name} is already stopped"
                }), 200

            container.stop(timeout=10)

        elif action == "restart":
            if container.status != "running":
                container.start()
            else:
                container.restart(timeout=10)

        container.reload()

        print(
            f"Container action completed: "
            f"{container_name} | {action} | {container.status}"
        )

        return jsonify({
            "success": True,
            "message": f"{container_name} {action} completed successfully",
            "container": {
                "name": container.name,
                "status": container.status
            }
        }), 200

    except NotFound:
        return jsonify({
            "success": False,
            "message": f"Container not found: {container_name}"
        }), 404

    except APIError as error:
        print("Docker action error:", error)

        return jsonify({
            "success": False,
            "message": f"Failed to {action} {container_name}",
            "error": str(error)
        }), 500

    except DockerException as error:
        print("Docker connection error:", error)

        return jsonify({
            "success": False,
            "message": "Unable to communicate with Docker Engine",
            "error": str(error)
        }), 500


@app.route('/api/containers/<string:container_name>/logs', methods=['GET'])
