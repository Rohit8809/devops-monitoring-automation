<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Rinktech Incident Management Dashboard</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    >

    <link
        rel="stylesheet"
        href="{{ url_for('static', filename='css/dashboard.css', v='6') }}"
    >
</head>

<body>

<div class="d-flex">

    <aside class="sidebar p-3">
        <h4 class="text-white mb-4">
            <i class="bi bi-shield-check"></i>
            Dashboard
        </h4>

        <nav class="nav flex-column">
            <a class="nav-link active" href="/dashboard">
                <i class="bi bi-grid"></i>
                Dashboard
            </a>

            <a class="nav-link" href="#">
                <i class="bi bi-exclamation-triangle"></i>
                Incidents
            </a>

            <a class="nav-link" href="#">
                <i class="bi bi-server"></i>
                Servers
            </a>

            <a class="nav-link" href="#">
                <i class="bi bi-box"></i>
                Containers
            </a>

            <a class="nav-link" href="#">
                <i class="bi bi-graph-up"></i>
                Monitoring
            </a>

            <a class="nav-link" href="#">
                <i class="bi bi-ticket-perforated"></i>
                Tickets
            </a>

            <a class="nav-link" href="#">
                <i class="bi bi-terminal"></i>
                Logs
            </a>
        </nav>
    </aside>

    <main class="main-content flex-grow-1">

        <header class="topbar d-flex justify-content-between align-items-center px-4">
            <div>
                <h5 class="mb-0">Rinktech Incident Management</h5>
                <small class="text-secondary">
                    Operations dashboard
                </small>
            </div>

            <div class="d-flex align-items-center gap-3">
                <button
                    type="button"
                    id="alert-indicator-button"
                    class="alert-indicator alert-indicator-healthy"
                    data-bs-toggle="modal"
                    data-bs-target="#activeAlertsModal"
                    title="View active alerts"
                >
                    <i
                        id="alert-indicator-icon"
                        class="bi bi-check-circle-fill"
                    ></i>

                    <span
                        id="active-alert-count"
                        class="alert-count-badge d-none"
                    >
                        0
                    </span>
                </button>

                <span class="fw-semibold">Rohit Kumar</span>
            </div>
        </header>

        <div class="container-fluid p-4">

            <div class="mb-4">
                <h2>Dashboard</h2>
                <p class="text-secondary mb-0">
                    TEST CHANGE FROM CONTAINER
                </p>
            </div>

            <div class="row g-4 mb-4">

                <div class="col-md-6 col-xl-3">
                    <div class="card summary-card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <p class="text-secondary mb-1">Total Containers</p>
                                    <h2 class="mb-0" id="total-containers">0</h2>
                                </div>
                                <i class="bi bi-server summary-icon"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="card summary-card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <p class="text-secondary mb-1">Running</p>
                                    <h2 class="mb-0 text-success" id="running-containers">0</h2>
                                </div>
                                <i class="bi bi-check-circle summary-icon text-success"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="card summary-card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <p class="text-secondary mb-1">Stopped</p>
                                    <h2 class="mb-0 text-danger" id="stopped-containers">0</h2>
                                </div>
                                <i class="bi bi-exclamation-octagon summary-icon text-danger"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-xl-3">
                    <div class="card summary-card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <p class="text-secondary mb-1">Open Incidents</p>
                                    <h2 class="mb-0 text-warning" id="open-incidents-count">0</h2>
                                </div>
                                <i class="bi bi-ticket-detailed summary-icon text-warning"></i>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">Infrastructure CPU Usage</h5>
                        <small class="text-secondary">
                            Separate one-hour CPU graphs fetched from Prometheus
                        </small>
                    </div>

                    <button
                        type="button"
                        class="btn btn-sm btn-outline-primary"
                        id="refresh-cpu-button"
                    >
                        <i class="bi bi-arrow-clockwise"></i>
                        Refresh Graphs
                    </button>
                </div>

                <div class="card-body">
                    <div
                        id="cpu-graph-message"
                        class="alert alert-danger d-none"
                    ></div>

                    <div class="row g-4">

                        <div class="col-12 col-xl-4">
                            <div class="metric-chart-card">
                                <div class="metric-chart-header">
                                    <h6 class="mb-1">Database Server</h6>
                                    <small class="text-secondary">
                                        db-server:9100
                                    </small>
                                </div>

                                <div class="chart-container chart-container-small">
                                    <canvas id="db-server-cpu-chart"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-xl-4">
                            <div class="metric-chart-card">
                                <div class="metric-chart-header">
                                    <h6 class="mb-1">Monitoring Server</h6>
                                    <small class="text-secondary">
                                        monitoring-server:9100
                                    </small>
                                </div>

                                <div class="chart-container chart-container-small">
                                    <canvas id="monitoring-server-cpu-chart"></canvas>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-xl-4">
                            <div class="metric-chart-card">
                                <div class="metric-chart-header">
                                    <h6 class="mb-1">Main Node Exporter</h6>
                                    <small class="text-secondary">
                                        node-exporter:9100
                                    </small>
                                </div>

                                <div class="chart-container chart-container-small">
                                    <canvas id="node-exporter-cpu-chart"></canvas>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">Docker Container Operations</h5>
                        <small class="text-secondary">
                            Live data fetched directly from Docker Engine
                        </small>
                    </div>

                    <button
                        class="btn btn-sm btn-outline-primary"
                        id="refresh-containers-button"
                        type="button"
                    >
                        <i class="bi bi-arrow-clockwise"></i>
                        Refresh
                    </button>
                </div>

                <div class="card-body p-0">
                    <div
                        id="container-message"
                        class="alert d-none m-3"
                        role="alert"
                    ></div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Container</th>
                                    <th>Image</th>
                                    <th>Status</th>
                                    <th>Container ID</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>

                            <tbody id="container-table-body">
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-secondary">
                                        <div class="spinner-border spinner-border-sm me-2"></div>
                                        Loading containers from Docker Engine...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0">Live Incident Management</h5>
                        <small class="text-secondary">
                            Tickets fetched directly from osTicket
                        </small>
                    </div>

                    <button
                        type="button"
                        class="btn btn-sm btn-outline-primary"
                        id="refresh-tickets-button"
                    >
                        <i class="bi bi-arrow-clockwise"></i>
                        Refresh Tickets
                    </button>
                </div>

                <div class="card-body p-0">
                    <div
                        id="ticket-message"
                        class="alert d-none m-3"
                        role="alert"
                    ></div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Ticket</th>
                                    <th>Subject</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Department</th>
                                    <th>Created</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody id="ticket-table-body">
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-secondary">
                                        <div class="spinner-border spinner-border-sm me-2"></div>
                                        Loading incidents from osTicket...
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Quick Access</h5>
                </div>

                <div class="card-body d-flex flex-wrap gap-2">

                    <a
                        href="http://localhost:9091"
                        target="_blank"
                        class="btn btn-outline-primary"
                    >
                        Open Prometheus
                    </a>

                    <a
                        href="http://localhost:9095"
                        target="_blank"
                        class="btn btn-outline-secondary"
                    >
                        Open Alertmanager
                    </a>

                    <a
                        href="http://localhost:8080"
                        target="_blank"
                        class="btn btn-outline-dark"
                    >
                        Open osTicket
                    </a>

                </div>
            </div>

        </div>
    </main>

</div>


<div
    class="modal fade"
    id="activeAlertsModal"
    tabindex="-1"
    aria-labelledby="activeAlertsModalLabel"
    aria-hidden="true"
>
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5
                        class="modal-title"
                        id="activeAlertsModalLabel"
                    >
                        Active Infrastructure Alerts
                    </h5>

                    <small
                        id="active-alert-summary"
                        class="text-secondary"
                    >
                        Checking Alertmanager...
                    </small>
                </div>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                    aria-label="Close"
                ></button>
            </div>

            <div class="modal-body">
                <div id="active-alerts-popup-content">
                    <div class="text-center py-5 text-secondary">
                        <div class="spinner-border spinner-border-sm me-2"></div>
                        Loading active alerts...
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button
                    type="button"
                    class="btn btn-outline-primary"
                    id="refresh-alerts-button"
                >
                    <i class="bi bi-arrow-clockwise"></i>
                    Refresh
                </button>

                <button
                    type="button"
                    class="btn btn-secondary"
                    data-bs-dismiss="modal"
                >
                    Close
                </button>
            </div>
        </div>
    </div>
</div>


<div
    class="modal fade"
    id="containerLogsModal"
    tabindex="-1"
    aria-labelledby="containerLogsModalLabel"
    aria-hidden="true"
>
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="containerLogsModalLabel">
                    Container Logs
                </h5>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                    aria-label="Close"
                ></button>
            </div>

            <div class="modal-body">
                <pre id="container-logs-output" class="container-logs">Loading logs...</pre>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script src="{{ url_for('static', filename='js/dashboard.js', v='6') }}"></script>

</body>
</html>
